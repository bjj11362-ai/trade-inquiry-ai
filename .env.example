DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
PORT=8787

MAIL_IMAP_HOST=imap.example.com
MAIL_IMAP_PORT=993
MAIL_IMAP_SECURE=true
MAIL_IMAP_USER=sales@example.com
MAIL_IMAP_PASSWORD=your-mail-app-password

MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_SMTP_USER=sales@example.com
MAIL_SMTP_PASSWORD=your-mail-app-password
MAIL_FROM="Sales Team <sales@example.com>"
MAIL_CONNECTION_TIMEOUT_MS=30000
MAIL_TLS_REJECT_UNAUTHORIZED=true
MAIL_FETCH_LIMIT=120
MAIL_PROCESS_LIMIT=10
MAIL_SEND_PROCESS_LIMIT=5
MAIL_LOOKBACK_DAYS=3

MAIL_POLL_INTERVAL_SECONDS=15
MAIL_LOOKBACK_DAYS=3

# Optional multi-mailbox mode. If set, this overrides the single MAIL_IMAP_* / MAIL_SMTP_* mailbox for syncing.
# Keep this as one JSON line in .env.
# MAIL_ACCOUNTS_JSON=[{"id":"qq-sales","label":"QQ Sales","imap":{"host":"imap.qq.com","port":993,"secure":true,"user":"sales@qq.com","pass":"qq-app-password"},"smtp":{"host":"smtp.qq.com","port":465,"secure":true,"user":"sales@qq.com","pass":"qq-app-password","from":"Sales <sales@qq.com>"}},{"id":"gmail-sales","label":"Gmail Sales","imap":{"host":"imap.gmail.com","port":993,"secure":true,"user":"sales@gmail.com","pass":"gmail-app-password"},"smtp":{"host":"smtp.gmail.com","port":465,"secure":true,"user":"sales@gmail.com","pass":"gmail-app-password","from":"Sales <sales@gmail.com>"}}]
