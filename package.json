{
  "name": "trade-inquiry-ai",
  "version": "0.1.0",
  "description": "AI trade inquiry automation workspace for Windows desktop.",
  "private": true,
  "main": "electron/app-main.cjs",
  "productName": "Trade Inquiry AI",
  "author": "bjj11362-ai",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "desktop": "npm run build && electron electron/app-main.cjs",
    "pet:web": "vite --host 127.0.0.1 --port 5174",
    "pet:desktop": "concurrently -k \"npm:pet:web\" \"node electron/start-electron.cjs\"",
    "build": "vite build",
    "dist:win": "npm run build && npm run dist:win:setup && npm run dist:win:portable",
    "dist:win:setup": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable",
    "preview": "vite preview --host 0.0.0.0",
    "test:mail": "node --test tests/mail.test.js",
    "test:risk": "node --test tests/risk.test.js"
  },
  "build": {
    "appId": "com.tradeinquiry.ai.desktop",
    "productName": "Trade Inquiry AI",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/app-main.cjs",
      "electron/app-preload.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "server/**/*",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
      "shortcutName": "Trade Inquiry AI",
      "uninstallDisplayName": "Trade Inquiry AI",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    }
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "imapflow": "^1.3.7",
    "lucide-react": "^0.561.0",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^7.3.5"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
