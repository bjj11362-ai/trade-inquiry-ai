{
  "name": "trade-inquiry-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "pet:web": "vite --host 127.0.0.1 --port 5174",
    "pet:desktop": "concurrently -k \"npm:pet:web\" \"node electron/start-electron.cjs\"",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:mail": "node --test tests/mail.test.js",
    "test:risk": "node --test tests/risk.test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "imapflow": "^1.3.7",
    "lucide-react": "^0.561.0",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.184.0",
    "vite": "^7.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.4.0"
  }
}
